# Copy this file to .env and fill in your values before deploying.

# IP address of the monitoring host (where Consul server, Loki, Prometheus run)
MONITORING_HOST=<MONITORING_HOST_IP>

# Consul node name for this monitored node (e.g. monitored-node-01)
CONSUL_NODE_NAME=monitored-node-01

# IP address that this node advertises to Consul (LAN IP of this machine)
CONSUL_ADVERTISE=<THIS_NODE_IP>

# Optional: override path to promtail config (defaults to ./promtail/config.yml)
# PROMTAIL_CONFIG_PATH=./promtail/config.yml
